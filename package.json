{
  "name": "tirri",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:quality": "tsc && vite build --mode quality",
    "build:production": "tsc && vite build --mode production",
    "preview:quality": "vite preview --mode quality",
    "preview:production": "vite preview --mode production",
    "deploy:quality": "npm run build:quality && firebase deploy",
    "deploy:production": "npm run build:production && firebase deploy",
    "docker:build": "docker build --no-cache --target production -t tertiary-delivery-management-frontend .",
    "docker:build:prod": "docker build --no-cache --target production -t tertiary-delivery-management-frontend:latest .",
    "docker:run": "docker run -it -d --name tertiary-delivery-management-frontend -p 3000:80 tertiary-delivery-management-frontend:latest",
    "docker:stop": "docker stop tertiary-delivery-management-frontend && docker rm tertiary-delivery-management-frontend",
    "docker": "npm run docker:build && (docker rm -f tertiary-delivery-management-frontend || echo Container not found) && npm run docker:run"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}